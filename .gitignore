# =============================================================================
# LLM Compare - .gitignore
# =============================================================================

# ── Archives ──────────────────────────────────────────────────────
*.zip
*.rar
*.7z
*.tar.gz
*.tar.bz2

# ── IDE / Editor ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# ── OS ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Node ─────────────────────────────────────────────────────────
node_modules/
package-lock.json
npm-debug.log
yarn-debug.log
yarn-error.log

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# ── LibreTranslate (external dependency) ─────────────────────────
LibreTranslate/

# ── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Temporary files ──────────────────────────────────────────────
*.tmp
*.temp
*.bak
nul

# ── Environment variables / Secrets ──────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
*.secret
api-keys.txt
key.txt

# ── Project-specific (not part of the codebase) ──────────────────
AGENTS.md
Commands.txt
opencode.json

# ── Translation helper scripts (one-time use) ────────────────────
translate.js
*.translate.*
bulk_translate.*
translate_all.*

# ── Build artifacts ──────────────────────────────────────────────
dist/
build/
out/

# ── Browser devtools ─────────────────────────────────────────────
.devtools/
.qwen/

# ── Coverage / Testing ───────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
.save/ 
