{
    "manifest_version": 2,
    "name": "LLM Compare — Сравнение AI моделей",
    "version": "5.1.0",
    "description": "Простой инструмент для сравнения ответов разных AI-чатов и ручной сборки итогового синтеза без API и локальных моделей.",
    "author": "LLM Compare",
    "permissions": [
        "storage",
        "activeTab",
        "tabs"
    ],
    "optional_permissions": [
        "http://localhost/*",
        "https://api.openai.com/*",
        "https://api.anthropic.com/*",
        "https://generativelanguage.googleapis.com/*",
        "https://api.deepseek.com/*",
        "https://api.groq.com/*",
        "https://api.mistral.ai/*",
        "https://api-inference.huggingface.co/*",
        "https://openrouter.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://deepseek.com/*",
        "https://chat.z.ai/*",
        "https://z.ai/*"
    ],
    "browser_action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "scripts": ["background.js"]
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "content_security_policy": "script-src 'self'; object-src 'self'; connect-src *; style-src 'self' 'unsafe-inline'; img-src 'self' data: *;"
}
